{
  "name": "@t8ngs/assert",
  "description": "Assertion module for T8ngs framework, built on top of Chai.",
  "version": "1.0.0",
  "engines": {
    "node": ">=18.16.0"
  },
  "type": "module",
  "files": [
    "dist",
    "!dist/tests"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/src/types.js"
  },
  "scripts": {
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "precompile": "npm run lint && npm run clean",
    "clean": "del-cli dist",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "quick:test": "glob -c \"node --import=ts-node-maintained/register/esm --enable-source-maps --test\" \"tests/**/*.spec.ts\"",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "commit": "cz"
  },
  "devDependencies": {
    "@arapucajs/eslint-config": "^1.1.2",
    "@arapucajs/prettier": "^1.1.1",
    "@arapucajs/tsconfig": "^1.0.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@swc/core": "^1.13.5",
    "@t8ngs/runner": "^1.0.1",
    "@t8ngs/show-screen-errors": "^1.0.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.5.2",
    "c8": "^10.1.3",
    "commitizen": "^4.3.1",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.36.0",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "luxon": "^3.7.2",
    "prettier": "^3.6.2",
    "ts-node-maintained": "^10.9.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "@t8ngs/runner": "^1.0.1 || ^4.0.0"
  },
  "homepage": "https://github.com/t8ngs/assert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t8ngs/assert.git"
  },
  "bugs": {
    "url": "https://github.com/t8ngs/assert/issues"
  },
  "keywords": [
    "assert",
    "chai",
    "t8ngs"
  ],
  "author": "JefteCosta <jefteamorim@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/types.ts"
    ],
    "outDir": "./dist",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": false,
    "target": "esnext"
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@arapucajs/prettier",
  "dependencies": {
    "@poppinss/macroable": "^1.1.0",
    "@types/chai": "^5.2.2",
    "assertion-error": "^2.0.1",
    "chai": "^6.2.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
    }
  }
}
